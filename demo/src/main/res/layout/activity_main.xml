<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗃️ aw-db 数据库演示"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <!-- 副标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Room数据库封装 · CRUD操作 · 事务管理 · Flow观察"
            android:textSize="13sp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 日志区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 操作日志"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#2196F3"
                android:padding="8dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#FFFFFF"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#333333" />

            </ScrollView>

        </LinearLayout>

        <!-- 基本操作分类 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 基本操作"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnInsert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="插入用户"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnBatchInsert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="批量插入(5个)"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnQueryAll"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="查询所有用户"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnQueryById"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="根据ID查询(ID=1)"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnUpsert"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="更新/插入用户"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="统计用户数"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDeleteAll"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="删除所有用户"
            android:layout_marginBottom="16dp" />

        <!-- 高级功能分类 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ 高级功能"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDbResult"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="测试 DbResult 包装"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnTransaction"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="测试 事务操作"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnBatchExecute"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="测试 批量执行"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnFlatMap"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="测试 flatMap 转换"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnObserveFlow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="观察 Flow 数据变化"
            android:layout_marginBottom="16dp" />

        <!-- 管理分类 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 管理"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🗑️ 清除日志"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</ScrollView>
